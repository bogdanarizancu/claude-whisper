{
  "name": "claude-whisper",
  "displayName": "Claude Whisper",
  "description": "Record your voice and send the transcription to the Claude Code input box",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "icon": "icon.png",
  "categories": ["AI", "Chat"],
  "keywords": ["voice", "speech", "whisper", "transcription", "claude", "dictation", "ai"],
  "repository": {
    "type": "git",
    "url": "https://github.com/bogdanarizancu/claude-whisper"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-whisper.sendToClaudeCode",
        "title": "Claude Whisper: Toggle Recording"
      }
    ],
    "keybindings": [
      {
        "command": "claude-whisper.sendToClaudeCode",
        "key": "ctrl+shift+v",
        "when": "activeWebviewPanelId == 'claudeVSCodePanel' || (claude-vscode.sideBarActive && !editorFocus && !panelFocus)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/test-cli": "^0.0.6",
    "@vscode/test-electron": "^2.3.8",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  }
}
